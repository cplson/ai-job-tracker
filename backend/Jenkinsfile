pipeline {
    agent any

    environment {
        BACKEND_DIR = "${env.BACKEND_DIR ?: 'backend'}"
        FRONTEND_DIR = "${env.FRONTEND_DIR ?: 'frontend'}"

        SNYK_CRED_ID = "snyk_creds"
        SNYK_INSTALLATION = "snyk@latest"

        TRIVY_SEVERITY = "HIGH,CRITICAL"
        JOBTRACKER_IMAGE = "jobtracker-api:latest"

        // Jenkins SonarQube server name (Manage Jenkins -> System -> SonarQube servers)
        SONARQUBE_ENV = "SonarQube"
        SONAR_PROJECT_KEY = "jobtracker-backend"
    }

    stages {
        stage('Checkout') {
            steps {
                git(
                    url: 'https://github.com/cplson/ai-job-tracker.git',
                    branch: 'main',
                    credentialsId: 'appserver'
                )
            }
        }

        stage('SonarQube Analysis') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    dir("${BACKEND_DIR}") {
                        withSonarQubeEnv("${SONARQUBE_ENV}") {
                            // Use a direct sh step (not inside script {}) so SONAR_HOST_URL / SONAR_AUTH_TOKEN reach the shell.
                            sh 'chmod +x scripts/run-sonar.sh && ./scripts/run-sonar.sh'
                            timeout(time: 5, unit: 'MINUTES') {
                                waitForQualityGate abortPipeline: false
                            }
                        }
                    }
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        junit allowEmptyResults: true, testResults: 'JobTracker.Tests/TestResults/**/*.xml'
                        archiveArtifacts artifacts: 'JobTracker.Tests/TestResults/**', allowEmptyArchive: true
                        archiveArtifacts artifacts: '**/coverage.cobertura.xml', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Snyk SAST') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    dir("${BACKEND_DIR}") {
                        withCredentials([string(credentialsId: "${SNYK_CRED_ID}", variable: 'SNYK_TOKEN')]) {
                            script {
                                def snykHome = tool name: "${SNYK_INSTALLATION}", type: 'io.snyk.jenkins.tools.SnykInstallation'
                                sh """
                                    ${snykHome}/snyk-linux code test \\
                                      --json-file-output=snyk-sast-report.json \\
                                      --sarif-file-output=snyk-sast-report.sarif
                                    if [ -f snyk-sast-report.json ]; then
                                      docker run --rm -v "\$(pwd):/work" -w /work node:20-alpine \\
                                        sh -c 'npx --yes snyk-to-html@3 -i snyk-sast-report.json -o snyk-sast-report.html'
                                      ls -la snyk-sast-report.html
                                    fi
                                """
                            }
                        }
                    }
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        archiveArtifacts artifacts: 'snyk-sast-report.json,snyk-sast-report.sarif,snyk-sast-report.html', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Security Scan') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'chmod +x scripts/run-owasp-zap.sh'
                    sh './scripts/run-owasp-zap.sh'
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        archiveArtifacts artifacts: 'zap-reports/**', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'docker build -t jobtracker-api:latest .'
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    dir("${BACKEND_DIR}") {
                        sh 'chmod +x scripts/run-trivy.sh'
                        sh './scripts/run-trivy.sh'
                    }
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        archiveArtifacts artifacts: 'trivy-reports/*.html,trivy-reports/*.json,trivy-reports/*.sarif', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm ci'
                    sh 'npm run build'
                }
            }
            post {
                always {
                    dir("${FRONTEND_DIR}") {
                        archiveArtifacts artifacts: 'dist/**', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'chmod +x scripts/deploy.sh'
                    sh './scripts/deploy.sh'
                }
            }
            post {
                always {
                    sh 'docker image prune -f || true'
                }
            }
        }
    }

    post {
        always {
            // Collect CI outputs from workspace (paths relative to repo root).
            archiveArtifacts artifacts: "${BACKEND_DIR}/JobTracker.Tests/TestResults/**", allowEmptyArchive: true
            archiveArtifacts artifacts: "${BACKEND_DIR}/**/coverage.cobertura.xml", allowEmptyArchive: true
            archiveArtifacts artifacts: "${BACKEND_DIR}/snyk-sast-report.html,${BACKEND_DIR}/snyk-sast-report.json,${BACKEND_DIR}/snyk-sast-report.sarif", allowEmptyArchive: true
            archiveArtifacts artifacts: "${BACKEND_DIR}/zap-reports/**", allowEmptyArchive: true
            archiveArtifacts artifacts: "${BACKEND_DIR}/trivy-reports/*.html,${BACKEND_DIR}/trivy-reports/*.json,${BACKEND_DIR}/trivy-reports/*.sarif", allowEmptyArchive: true
            archiveArtifacts artifacts: "${FRONTEND_DIR}/dist/**", allowEmptyArchive: true
        }
    }
}
