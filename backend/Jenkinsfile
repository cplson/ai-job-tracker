pipeline {
    agent any

    environment {
        BACKEND_DIR = "${env.BACKEND_DIR ?: 'backend'}"
        FRONTEND_DIR = "${env.FRONTEND_DIR ?: 'frontend'}"

        SNYK_CRED_ID = "s_credentials_id"
        SNYK_SECRET = "snyk_token"

        TRIVY_SEVERITY = "HIGH,CRITICAL"
    }

    stages {
        stage('Checkout') {
            steps {
                git(
                    url: 'https://github.com/cplson/ai-job-tracker.git',
                    branch: 'main',
                    credentialsId: 'appserver'
                )
            }
        }

        stage('Build') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'dotnet restore JobTracker.sln'
                    sh 'dotnet build JobTracker.sln --configuration Release'
                }
            }
        }

        stage('Test') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh '''
                        dotnet test JobTracker.Tests/JobTracker.Tests.csproj \
                          --settings JobTracker.Tests/test.runsettings \
                          --results-directory JobTracker.Tests/TestResults \
                          --logger "junit;LogFileName=test_results.xml"
                    '''
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        junit allowEmptyResults: false, testResults: 'JobTracker.Tests/TestResults/*.xml'
                    }
                }
            }
        }

        stage('Snyk SAST') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    dir("${BACKEND_DIR}") {
                        withCredentials([string(credentialsId: "${SNYK_CRED_ID}", variable: 'SNYK_TOKEN')]) {
                            sh '''
                                snyk code test \
                                  --json-file-output=snyk-sast-report.json \
                                  --sarif-file-output=snyk-sast-report.sarif
                            '''
                        }
                    }
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        archiveArtifacts artifacts: 'snyk-sast-report.*', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Security Scan') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'chmod +x scripts/run-owasp-zap.sh'
                    sh './scripts/run-owasp-zap.sh'
                }
            }
            post {
                always {
                    dir("${BACKEND_DIR}") {
                        archiveArtifacts artifacts: 'zap-reports/zap-report.html', allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'docker build -t jobtracker-api:latest .'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm ci'
                    sh 'npm run build'
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'chmod +x scripts/deploy.sh'
                    sh './scripts/deploy.sh'
                }
            }
            post {
                always {
                    sh 'docker image prune -f || true'
                }
            }
        }
    }
}
