# Copy to .env and fill in values before deploy

POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=change_me
POSTGRES_DB=JobTrackerDb

API_PORT=5001

Jwt__Key=change_me_to_a_long_random_secret_at_least_32_chars
Jwt__Issuer=JobTrackerAPI
Jwt__Audience=JobTrackerClient

OPEN_AI_KEY=sk-your-openai-key

# Comma-separated origins for CORS (must match browser URL)
Cors__AllowedOrigins=http://localhost:5173,http://YOUR_LINODE_IP

# Frontend build (Vite) — use same origin as nginx serves
VITE_API_URL=http://YOUR_LINODE_IP/api
