<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <ASPNETCORE_ENVIRONMENT>Testing</ASPNETCORE_ENVIRONMENT>
      <Jwt__Key>IntegrationTestJwtSigningKey_MustBe32CharsOrMore!</Jwt__Key>
      <Jwt__Issuer>JobTrackerAPI</Jwt__Issuer>
      <Jwt__Audience>JobTrackerClient</Jwt__Audience>
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
